# Serial
SERIAL_PORT=COM3
SERIAL_BAUD=9600

# Live room id (must match shared/campus-seed.json)
LIVE_ROOM_ID=vari-a
THRESHOLD_C=25

# Firebase
FIREBASE_PROJECT_ID=hallsense-demo
# For emulator (local-first):
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# For production, unset emulator vars and set:
# GOOGLE_APPLICATION_CREDENTIALS=../serviceAccount.json

# Expo push rate limit (seconds between alerts while overheating)
PUSH_COOLDOWN_SEC=60
